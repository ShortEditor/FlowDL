# Environment Variables — Backend

# The Vercel frontend URL to allow via CORS.
# Set this on Render after deploying the frontend to Vercel.
# Example: https://flowdl.vercel.app
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: Netscape-format YouTube cookies string to bypass anti-bot blocks on servers
# Extract cookies from browser, paste the whole text content here.
# YT_COOKIES="# Netscape HTTP Cookie File..."
